<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NEXUS DIAGNOSTICS" Height="660" Width="1020"
        MinHeight="600" MinWidth="900"
        WindowState="Maximized" WindowStartupLocation="CenterScreen"
        Background="#0a0a0a"
        FontFamily="Poppins, Inter, Segoe UI">
    <Window.Resources>
        <!-- Lucide-style icon geometries (24x24, stroke) -->
        <Geometry x:Key="IconGlobe">M2,12 A10,10 0 1 1 22,12 A10,10 0 1 1 2,12 M12,2 A14.5,14.5 0 0 0 12,22 A14.5,14.5 0 0 0 12,2 M2,12 H22</Geometry>
        <Geometry x:Key="IconDrive">M22,12 H2 M5.45,5.11 2,12 v6 a2,2 0 0 0 2,2 h16 a2,2 0 0 0 2,-2 v-6 l-3.45,-6.89 A2,2 0 0 0 16.76,4 H7.24 a2,2 0 0 0 -1.79,1.11 z M6,16 h0.01 M10,16 h0.01</Geometry>
        <Geometry x:Key="IconShield">M20,13 c0,5 -3.5,7.5 -7.66,8.95 a1,1 0 0 1 -0.67,-0.01 C7.5,20.5 4,18 4,13 V6 a1,1 0 0 1 1,-1 c2,0 4.5,-1.2 6.24,-2.72 a1.17,1.17 0 0 1 1.52,0 C14.51,3.81 17,5 19,5 a1,1 0 0 1 1,1 z M9,12 11,14 15,10</Geometry>
        <Geometry x:Key="IconTrash">M3,6 H21 M19,6 V20 c0,1 -1,2 -2,2 H7 c-1,0 -2,-1 -2,-2 V6 M8,6 V4 c0,-1 1,-2 2,-2 h4 c1,0 2,1 2,2 v2 M10,11 V17 M14,11 V17</Geometry>
        <Geometry x:Key="IconScroll">M15,12 H10 M15,8 H10 M19,17 V5 a2,2 0 0 0 -2,-2 H4 M8,21 h12 a2,2 0 0 0 2,-2 v-1 a1,1 0 0 0 -1,-1 H11 a1,1 0 0 0 -1,1 v1 a2,2 0 1 1 -4,0 V5 a2,2 0 1 0 -4,0 v2 a1,1 0 0 0 1,1 h3</Geometry>
        <Geometry x:Key="IconWrench">M14.7,6.3 a1,1 0 0 0 0,1.4 l1.6,1.6 a1,1 0 0 0 1.4,0 l3.77,-3.77 a6,6 0 0 1 -7.94,7.94 l-6.91,6.91 a2.12,2.12 0 0 1 -3,-3 l6.91,-6.91 a6,6 0 0 1 7.94,-7.94 l-3.76,3.76 z</Geometry>
        <Geometry x:Key="IconInfo">M2,12 A10,10 0 1 1 22,12 A10,10 0 1 1 2,12 M12,16 V12 M12,8 h0.01</Geometry>
        <Geometry x:Key="IconRefresh">M3,12 a9,9 0 0 1 9,-9 9.75,9.75 0 0 1 6.74,2.74 L21,8 M21,3 v5 h-5 M21,12 a9,9 0 0 1 -9,9 9.75,9.75 0 0 1 -6.74,-2.74 L3,16 M3,21 v-5 h5</Geometry>
        <Geometry x:Key="IconCloud">M17.5,19 H9 a7,7 0 1 1 6.71,-9 h1.79 a4.5,4.5 0 1 1 0,9 Z</Geometry>
        <Geometry x:Key="IconEraser">M7,21 2.7,16.7 c-1,-1 -1,-2.5 0,-3.4 l9.6,-9.6 c1,-1 2.5,-1 3.4,0 l5.6,5.6 c1,1 1,2.5 0,3.4 L13,21 M22,21 H7 M5,11 14,20</Geometry>

        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="#141414"/>
            <Setter Property="Foreground" Value="#fafafa"/>
            <Setter Property="BorderBrush" Value="#1f1f1f"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,11"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="17" Height="17" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <Path Data="{TemplateBinding Tag}" Stroke="{TemplateBinding Foreground}" StrokeThickness="2"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                          Width="24" Height="24" Stretch="None"/>
                                </Viewbox>
                                <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1b1b1b"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#e4ff3a"/>
                                <Setter Property="Foreground" Value="#e4ff3a"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#202200"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#e4ff3a"/>
                                <Setter Property="Foreground" Value="#e4ff3a"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavTile" TargetType="Button">
            <Setter Property="Background" Value="#141414"/>
            <Setter Property="Foreground" Value="#fafafa"/>
            <Setter Property="BorderBrush" Value="#1f1f1f"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Height" Value="106"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="8,12">
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Viewbox Width="25" Height="25" HorizontalAlignment="Center" Margin="0,0,0,8">
                                    <Path Data="{TemplateBinding Tag}" Stroke="{TemplateBinding Foreground}" StrokeThickness="2"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                          Width="24" Height="24" Stretch="None"/>
                                </Viewbox>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <ContentPresenter.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextWrapping" Value="Wrap"/>
                                            <Setter Property="TextAlignment" Value="Center"/>
                                            <Setter Property="LineHeight" Value="15"/>
                                        </Style>
                                    </ContentPresenter.Resources>
                                </ContentPresenter>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1b1b1b"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#e4ff3a"/>
                                <Setter Property="Foreground" Value="#e4ff3a"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#202200"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#e4ff3a"/>
                                <Setter Property="Foreground" Value="#e4ff3a"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NexusScrollThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="thumb" Background="#2a2a2a" CornerRadius="4" Margin="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="thumb" Property="Background" Value="#3f3f3f"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="thumb" Property="Background" Value="#e4ff3a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="RepeatButton" x:Key="NexusScrollHidden">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource NexusScrollHidden}" Command="ScrollBar.PageUpCommand"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource NexusScrollThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource NexusScrollHidden}" Command="ScrollBar.PageDownCommand"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="10"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent">
                                    <Track x:Name="PART_Track" Orientation="Horizontal">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource NexusScrollHidden}" Command="ScrollBar.PageLeftCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource NexusScrollThumb}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource NexusScrollHidden}" Command="ScrollBar.PageRightCommand"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="32">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" BorderBrush="#1f1f1f" BorderThickness="1" Background="#111111" CornerRadius="8" Padding="24">
            <DockPanel>
                <StackPanel DockPanel.Dock="Bottom">
                    <Border Height="1" Background="#1f1f1f" Margin="0,18,0,18"/>
                    <Button x:Name="btnClear" Style="{StaticResource NavButton}" Tag="{StaticResource IconEraser}" Content="Purge terminal" Foreground="#a3a3a3"/>
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,4,0">
                    <StackPanel Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Image x:Name="imgLogo" Width="34" Height="34" VerticalAlignment="Center" Margin="0,2,0,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Text="NEXUS" Foreground="#fafafa" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Tech Tools Suite" Foreground="#525252" FontFamily="JetBrains Mono, Consolas" FontSize="11" Margin="8,0,0,14"/>

                        <Border Height="1" Background="#1f1f1f" Margin="0,0,0,12"/>

                        <TextBlock x:Name="txtAdminStatus" Text="Auth: checking" Foreground="#a3a3a3" FontFamily="JetBrains Mono, Consolas" FontSize="11" Margin="0,0,0,10"/>

                        <UniformGrid Columns="3" Margin="-4,0">
                            <Button x:Name="btnNetworkDiag" Style="{StaticResource NavTile}" Tag="{StaticResource IconGlobe}" Content="Network diagnostics" />
                            <Button x:Name="btnDiskCheck" Style="{StaticResource NavTile}" Tag="{StaticResource IconDrive}" Content="Disk usage analysis" />
                            <Button x:Name="btnImageVerify" Style="{StaticResource NavTile}" Tag="{StaticResource IconShield}" Content="Verify system image" />
                            <Button x:Name="btnCleanTemp" Style="{StaticResource NavTile}" Tag="{StaticResource IconTrash}" Content="Clean temporary files" />
                            <Button x:Name="btnEventViewer" Style="{StaticResource NavTile}" Tag="{StaticResource IconScroll}" Content="Event Viewer analysis" />
                            <Button x:Name="btnAppSolutions" Style="{StaticResource NavTile}" Tag="{StaticResource IconWrench}" Content="Application solutions" />
                        </UniformGrid>

                        <StackPanel x:Name="panelOffice" Visibility="Collapsed" Margin="14,2,0,0">
                            <TextBlock Text="Microsoft Office" Foreground="#525252" FontFamily="JetBrains Mono, Consolas" FontSize="10" Margin="2,8,0,0"/>
                            <Button x:Name="btnOfficeInfo" Style="{StaticResource NavButton}" Tag="{StaticResource IconInfo}" Content="Office install info" FontSize="12" Padding="12,9"/>
                            <Button x:Name="btnOfficeQuick" Style="{StaticResource NavButton}" Tag="{StaticResource IconRefresh}" Content="Quick repair" FontSize="12" Padding="12,9"/>
                            <Button x:Name="btnOfficeOnline" Style="{StaticResource NavButton}" Tag="{StaticResource IconCloud}" Content="Online repair" FontSize="12" Padding="12,9"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Margin="26,0,0,0" BorderBrush="#1f1f1f" BorderThickness="1" Background="#0a0a0a" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#111111" BorderBrush="#1f1f1f" BorderThickness="0,0,0,1" Padding="22,14" CornerRadius="8,8,0,0">
                    <Grid>
                        <TextBlock Text="~/nexus - diagnostic output" Foreground="#525252" FontFamily="JetBrains Mono, Consolas" FontSize="12" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Ellipse Width="8" Height="8" Fill="#22c55e" Margin="0,0,7,0"/>
                            <TextBlock Text="LIVE" Foreground="#22c55e" FontFamily="JetBrains Mono, Consolas" FontSize="11" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <ScrollViewer Grid.Row="1" x:Name="scrollViewer" VerticalScrollBarVisibility="Auto" Margin="22,18,14,18" Padding="0,0,6,0">
                    <TextBlock x:Name="txtOutput" Foreground="#e5e5e5" FontFamily="JetBrains Mono, Consolas" FontSize="13" TextWrapping="Wrap" />
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
