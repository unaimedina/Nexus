<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NEXUS DIAGNOSTICS" Height="660" Width="1020"
        Background="#0a0a0a" WindowStartupLocation="CenterScreen"
        FontFamily="Poppins, Inter, Segoe UI">
    <Window.Resources>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="#141414"/>
            <Setter Property="Foreground" Value="#fafafa"/>
            <Setter Property="BorderBrush" Value="#1f1f1f"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,11"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1b1b1b"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#e4ff3a"/>
                                <Setter Property="Foreground" Value="#e4ff3a"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#202200"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#e4ff3a"/>
                                <Setter Property="Foreground" Value="#e4ff3a"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NexusScrollThumb" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="thumb" Background="#2a2a2a" CornerRadius="4" Margin="2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="thumb" Property="Background" Value="#3f3f3f"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="thumb" Property="Background" Value="#e4ff3a"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="RepeatButton" x:Key="NexusScrollHidden">
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="IsTabStop" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource NexusScrollHidden}" Command="ScrollBar.PageUpCommand"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource NexusScrollThumb}"/>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource NexusScrollHidden}" Command="ScrollBar.PageDownCommand"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto"/>
                    <Setter Property="Height" Value="10"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent">
                                    <Track x:Name="PART_Track" Orientation="Horizontal">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource NexusScrollHidden}" Command="ScrollBar.PageLeftCommand"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource NexusScrollThumb}"/>
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource NexusScrollHidden}" Command="ScrollBar.PageRightCommand"/>
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid Margin="32">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" BorderBrush="#1f1f1f" BorderThickness="1" Background="#111111" CornerRadius="8" Padding="24">
            <DockPanel>
                <StackPanel DockPanel.Dock="Bottom">
                    <Border Height="1" Background="#1f1f1f" Margin="0,18,0,18"/>
                    <Button x:Name="btnClear" Style="{StaticResource NavButton}" Content="&gt;  Purge terminal" Foreground="#a3a3a3"/>
                </StackPanel>

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,4,0">
                    <StackPanel Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Image x:Name="imgLogo" Width="34" Height="34" VerticalAlignment="Center" Margin="0,2,0,0" RenderOptions.BitmapScalingMode="HighQuality"/>
                            <TextBlock Text="NEXUS" Foreground="#fafafa" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Tech Tools Suite" Foreground="#525252" FontFamily="JetBrains Mono, Consolas" FontSize="11" Margin="8,0,0,22"/>

                        <Border Height="1" Background="#1f1f1f" Margin="0,0,0,18"/>

                        <TextBlock x:Name="txtAdminStatus" Text="auth: checking" Foreground="#a3a3a3" FontFamily="JetBrains Mono, Consolas" FontSize="11" Margin="0,0,0,12"/>

                        <Button x:Name="btnNetworkDiag" Style="{StaticResource NavButton}" Content="&gt;  Network diagnostics" />
                        <Button x:Name="btnDiskCheck" Style="{StaticResource NavButton}" Content="&gt;  Disk usage analysis" />
                        <Button x:Name="btnImageVerify" Style="{StaticResource NavButton}" Content="&gt;  Verify system image" />
                        <Button x:Name="btnAppSolutions" Style="{StaticResource NavButton}" Content="&gt;  Application solutions" />

                        <StackPanel x:Name="panelOffice" Visibility="Collapsed" Margin="14,2,0,0">
                            <TextBlock Text="Microsoft Office" Foreground="#525252" FontFamily="JetBrains Mono, Consolas" FontSize="10" Margin="2,8,0,0"/>
                            <Button x:Name="btnOfficeInfo" Style="{StaticResource NavButton}" Content="&gt;  Office install info" FontSize="12" Padding="12,9"/>
                            <Button x:Name="btnOfficeQuick" Style="{StaticResource NavButton}" Content="&gt;  Quick repair" FontSize="12" Padding="12,9"/>
                            <Button x:Name="btnOfficeOnline" Style="{StaticResource NavButton}" Content="&gt;  Online repair" FontSize="12" Padding="12,9"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" Margin="26,0,0,0" BorderBrush="#1f1f1f" BorderThickness="1" Background="#0a0a0a" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#111111" BorderBrush="#1f1f1f" BorderThickness="0,0,0,1" Padding="22,14" CornerRadius="8,8,0,0">
                    <Grid>
                        <TextBlock Text="~/nexus - diagnostic output" Foreground="#525252" FontFamily="JetBrains Mono, Consolas" FontSize="12" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Ellipse Width="8" Height="8" Fill="#22c55e" Margin="0,0,7,0"/>
                            <TextBlock Text="LIVE" Foreground="#22c55e" FontFamily="JetBrains Mono, Consolas" FontSize="11" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <ScrollViewer Grid.Row="1" x:Name="scrollViewer" VerticalScrollBarVisibility="Auto" Margin="22,18,14,18" Padding="0,0,6,0">
                    <TextBlock x:Name="txtOutput" Foreground="#e5e5e5" FontFamily="JetBrains Mono, Consolas" FontSize="13" TextWrapping="Wrap" />
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>
